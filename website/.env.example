# 无界科技 BOUNDLESS · 网站(Next.js) 环境变量模板
# 复制为 .env.local（本地）或在部署平台(Vercel 等)配置。.env*.local 已被 git 忽略。
# 标注：[必填] 不配则该功能不可用；[建议] 影响安全/正确性；[可选] 有合理默认值。
#
# 部署后自检（确认 token / webhook / 存储 / AI 就绪，不泄露密钥值）：
#   curl -H "x-setup-key: <TELEGRAM_SETUP_KEY>" "https://<域名>/api/telegram/setup … "
#   curl -H "x-setup-key: <TELEGRAM_SETUP_KEY>" "https://<域名>/api/health?deep=1"
#     → checks.env(各项布尔) / checks.telegram.webhook(url/pending/lastError) / storage

# ── 必填：核心功能 ────────────────────────────────────────────
# Telegram Bot API token（BotFather 获取）。不配则 bot / 频道 / webhook 全部不工作。
TELEGRAM_BOT_TOKEN=123456789:AA...replace-me
# 高权限部署/运维口令：保护 /api/telegram/setup、定时任务、/bindadmin；也是 ADMIN_KEY 的回退。
TELEGRAM_SETUP_KEY=change-me-strong-random
# AI 对话（DeepSeek）密钥。不配则 AI 回复不可用（其余功能正常）。
DEEPSEEK_API_KEY=sk-...replace-me

# ── 建议：安全 / 正确性 ───────────────────────────────────────
# Webhook 校验密钥：防伪造回推。setup 设 webhook 时用同一值；两端必须一致，否则回推被 403。
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret
# 后台登录口令（日常运营）。不配则回退使用 TELEGRAM_SETUP_KEY。
ADMIN_KEY=change-me-admin
# 站点根 URL：影响 webhook 地址、菜单按钮、OG 图、分享链接。
# 注意：NEXT_PUBLIC_* 在「构建时」内联，必须在构建环境就设置好。默认 https://usdt2026.cc
NEXT_PUBLIC_SITE_URL=https://usdt2026.cc

# ── 可选：Telegram 平台实体覆盖（均有默认，改 username 需同步在 Telegram 端操作）──
NEXT_PUBLIC_BOT_HANDLE=tgzkw_bot
NEXT_PUBLIC_TELEGRAM_HANDLE=ai_zkw
NEXT_PUBLIC_TELEGRAM_CHANNEL=hykj7
NEXT_PUBLIC_TELEGRAM_GROUP=hykjz

# ── 可选：留资通知 / 群应答 ──────────────────────────────────
# 留资推送目标 chat_id（也可在 bot 内发送 /bindadmin <TELEGRAM_SETUP_KEY> 动态绑定）。
TELEGRAM_CHAT_ID=
# 除 @群 外，额外允许 bot 应答的群 id（逗号分隔）。
TELEGRAM_GROUP_IDS=

# ── 可选：AI 调参（有默认）───────────────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
# DeepSeek 熔断器：连续失败阈值(默认3) / 熔断打开时长ms
DS_FAIL_THRESHOLD=3
# DS_OPEN_MS=

# ── 可选：运营 / 阈值 / 定时（有默认）────────────────────────
# AI 对话每日上限（默认 2000）
CHAT_DAILY_CAP=2000
# 每日自动发布开关："1" 开启
DAILY_AUTO_PUBLISH=0
# 解锁码有效天数（默认 7）
UNLOCK_TTL_DAYS=7
# 时区偏移小时（默认 8）
TZ_OFFSET=8
# 健康日报推送小时(默认9) / 连续异常升级次数 / 重复告警间隔ms
HEALTH_DIGEST_HOUR=9
# HEALTH_ESCALATE_N=
# HEALTH_REALERT_MS=
# 服务器侧健康看护(scripts/health-watchdog.sh, cron 每2分钟)的告警目标 chat_id。
# 连续2次 /api/health 不健康并自动重启 pm2 时，向此 chat 推送告警；留空则只自愈不通知。
ALERT_CHAT_ID=

# ── 可选：数据 / 日志 / 存储路径（默认在 ~/hualing-leads 同目录，一般无需改）──
# LEADS_DIR=  # 数据根目录，默认 ~/hualing-leads（自动从旧 ~/yuntech-leads 兼容迁移）
# 其余路径变量（均派生自 LEADS_DIR，仅在需要分离存储时覆盖）：
# LEADS_DB / LEADS_LOG / ANALYTICS_DIR / ANALYTICS_LOG / CHAT_LOG / CHAT_USAGE /
# PUBLISH_LOG / ALERT_LOG / KB_EXTRA_LOG / ADMIN_CHAT_STORE / CATALOG_STORE /
# SCHEDULE_STORE / UNLOCK_STORE / HEALTH_STATE
