# Telegram会话文件
sessions/*.session
sessions/*.session-journal
!sessions/.gitkeep
# 登录临时密钥文件（脚本用完即删；此处兜底防中断残留入库）
code.txt
2fa_password.txt
# 账号注册表（含加密会话；运行时落地）
config/account_registry.db
config/account_registry.db-*

# 协议账号下载的入站媒体（运行时落地，含用户内容，勿入库）
src/web/static/protocol_media/

# 日志 — 全目录 ignore（drafts.json / trigger_decisions.log / KB trace 可能含 PII）
# 用 **/logs/ 覆盖根目录和任何子目录（如 config/logs/kb_direct_trace.jsonl）
**/logs/*
!**/logs/.gitkeep

# 配置文件（不包含实际凭证）
config/config.yaml
# P1-1 接入向导写入的凭证 overlay（含密钥，绝不入库）
config/config.local.yaml
# 陪伴能力分阶段开启的开关审计 + 回滚快照（运行时产物）
config/companion_capability_audit.jsonl
config/companion_capability_last_snapshot.json

# C0-1 授权：客户授权码 + 厂商私钥（切勿入库）
config/license.key
config/.vendor_license_private.pem
*.vendor_license_private.pem

# SQLite 数据库（所有变体，含 WAL/SHM/备份）
*.db
*.db-shm
*.db-wal
*.db.bak*
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal

# Config 运行时产物 — 含设备 IP/序列号校准、配置历史快照、备份
config/data/
config/backups/
config/snapshots/

# Messenger RPA 截图 + replays（含他人对话）
tmp_messenger_rpa/
tmp_e2e_screens/
tmp_screenshots/
tmp_voice_notes/
tmp_voice_replies/

# 用户语音样本（PII：用户本人 .wav + consent 文件，不入库）
voice_samples/
tools/voice_samples/

# 声纹克隆参考音频（PII/版权：真人声样本，如 lin_xiaoyu.wav / liu_dehua.wav / 刘德华声音台词.wma）
config/voice_refs/*.wav
config/voice_refs/*.wma
config/voice_refs/*.mp3
config/voice_refs/*.m4a
!config/voice_refs/.gitkeep
*.wma

# 账号自身/联系人头像（运行时下载的真实头像 = PII，勿入库）
src/web/static/persona_avatars/

# Messenger web 登录调试转储（截图/DOM/请求 dump 可能含 session token/PII）
services/messenger-web/_*.png
services/messenger-web/_*.json
services/*/_*.png
services/*/_dom_dump.json
services/*/_requests_dump.json

# scripts 下临时脚本（一次性，非入库）
scripts/_tmp_*.py

# ML 模型完整目录（whisper 等大权重，216M 级别）
models/

# 一次性调试脚本（不应入库）
check_deferred.py
check_deferred2.py
check_tables.py
check_vz.py
tmp_check_db.py

